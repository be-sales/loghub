{
  "name": "loghub",
  "version": "1.0.0",
  "private": true,
  "description": "Централизованный сервис сбора и публикации error-логов в Telegram",
  "license": "UNLICENSED",
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:admin-ui": "node ./scripts/build-admin-ui.mjs",
    "build": "yarn build:admin-ui && nest build",
    "dev": "yarn build:admin-ui && nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test,packages/*/src}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test,packages/*/src}/**/*.ts\" --fix",
    "lint:errors": "eslint \"{src,test,packages/*/src}/**/*.ts\" --quiet",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.config.ts",
    "db:generate": "yarn prisma generate",
    "db:migrate": "yarn prisma migrate dev",
    "db:migrate:prod": "yarn prisma migrate deploy",
    "db:seed": "yarn prisma db seed",
    "db:studio": "yarn prisma studio",
    "sdk:build": "yarn workspace @besales/loghub-client build"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^9.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/schedule": "^5.0.0",
    "@nestjs/swagger": "^8.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "ioredis": "^5.4.0",
    "joi": "^17.0.0",
    "jsonwebtoken": "^9.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "esbuild": "^0.25.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "prisma": "^6.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.0.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
