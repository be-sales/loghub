# App
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Database
DATABASE_URL=postgresql://user:pass@host:5432/loghub

# Redis
REDIS_URL=redis://default:pass@host:6379

# Telegram
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff12345678901
TELEGRAM_FORUM_CHAT_ID=-1001234567890

# Admin
ADMIN_LOGIN=admin
ADMIN_PASSWORD=<strong-password-min-12-chars>
ADMIN_JWT_SECRET=<random-secret-min-32-chars>

# HMAC secret для хеширования API-ключей (min 32 символа, случайная строка)
# Смена этого значения аннулирует все существующие API-ключи в БД!
HMAC_SECRET=<random-secret-min-32-chars>

# Logging
LOG_LEVEL=info

# CORS — конкретный origin без wildcard (*), например: http://localhost:3000
CORS_ORIGIN=http://localhost:3000
